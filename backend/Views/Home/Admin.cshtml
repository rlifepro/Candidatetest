@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="min-h-screen bg-gray-100">
    <!-- Navigation Header -->
    <nav class="bg-white shadow-md">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <h1 class="text-xl font-bold text-gray-800">Admin Panel</h1>
                </div>
                <div class="flex items-center space-x-4">
                    <a href="/Home/Admin" class="text-gray-700 hover:text-blue-600 px-3 py-2 rounded-md text-sm font-medium">Dashboard</a>
                    <a href="/Home/Candidates" class="text-gray-700 hover:text-blue-600 px-3 py-2 rounded-md text-sm font-medium">Manage Candidates</a>
                    <a href="/Home/Questions" class="text-gray-700 hover:text-blue-600 px-3 py-2 rounded-md text-sm font-medium">Manage Questions</a>
                    <button onclick="logout()" class="bg-red-600 text-white px-3 py-2 rounded-md text-sm font-medium hover:bg-red-700">Logout</button>
                </div>
            </div>
        </div>
    </nav>

    <div class="max-w-7xl mx-auto py-6 px-4 sm:px-6 lg:px-8">
        <div class="bg-white rounded-lg shadow-md p-6">
            <h1 class="text-3xl font-bold text-gray-800 mb-6">Admin Dashboard</h1>
            <div class="grid gap-6 lg:grid-cols-2">
                <div class="rounded-lg border p-4">
                    <h2 class="text-xl font-semibold text-gray-700 mb-3">Live Candidate Monitoring</h2>
                    <ul id="liveList" class="space-y-2 max-h-64 overflow-y-auto"></ul>
                </div>
                <div class="rounded-lg border p-4">
                    <h2 class="text-xl font-semibold text-gray-700 mb-3">Score Chart</h2>
                    <canvas id="scoreChart" height="200"></canvas>
                </div>
            </div>
            <div class="mt-6 rounded-lg border p-4">
                <h2 class="text-xl font-semibold text-gray-700 mb-3">Result History</h2>
                <div class="overflow-x-auto">
                    <table class="min-w-full table-auto text-left text-sm">
                        <thead>
                            <tr class="bg-gray-50">
                                <th class="px-4 py-2 font-medium text-gray-700">Candidate</th>
                                <th class="px-4 py-2 font-medium text-gray-700">Score</th>
                                <th class="px-4 py-2 font-medium text-gray-700">Submitted At</th>
                            </tr>
                        </thead>
                        <tbody id="resultTableBody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function logout() {
        localStorage.removeItem('token');
        window.location.href = '/Home/Index';
    }

    const liveList = document.getElementById('liveList');
    const ctx = document.getElementById('scoreChart').getContext('2d');

    const scoreChart = new Chart(ctx, {
        type: 'bar',
        data: {
            labels: [],
            datasets:[{label:'Score', data: [], backgroundColor:'#3B82F6'}]
        },
        options:{
            responsive:true,
            scales:{
                y:{
                    max:100,
                    min:0,
                    ticks: { stepSize: 10 }
                }
            },
            plugins: {
                legend: { display: false }
            }
        }
    });

    const connection = new signalR.HubConnectionBuilder().withUrl('/hubs/live').build();

    const results = [];

    connection.on('CandidateScoreUpdated', data => {
        const item = document.createElement('li');
        item.className = 'rounded-lg border p-3 bg-gray-50';
        const candidate = data.user ?? data.candidateId;
        item.textContent = `${candidate} -> ${data.score}%`;
        liveList.prepend(item);

        // Keep only last 10 items
        while (liveList.children.length > 10) {
            liveList.removeChild(liveList.lastChild);
        }

        const existingIndex = results.findIndex(r => r.user === candidate);
        if (existingIndex >= 0) {
            results[existingIndex].score = data.score;
            results[existingIndex].submittedAt = new Date().toLocaleString();
        } else {
            results.push({ user: candidate, score: data.score, submittedAt: new Date().toLocaleString() });
        }

        if (!scoreChart.data.labels.includes(candidate)) {
            scoreChart.data.labels.push(candidate);
            scoreChart.data.datasets[0].data.push(data.score);
        } else {
            const idx = scoreChart.data.labels.indexOf(candidate);
            scoreChart.data.datasets[0].data[idx] = data.score;
        }
        scoreChart.update();

        renderResultTable();
    });

    function renderResultTable() {
        const tableBody = document.getElementById('resultTableBody');
        tableBody.innerHTML = '';
        results.sort((a,b)=>b.score-a.score);
        results.forEach(row => {
            const tr = document.createElement('tr');
            tr.className = 'border-t';
            tr.innerHTML = `<td class='px-4 py-3'>${row.user}</td><td class='px-4 py-3'>${row.score}%</td><td class='px-4 py-3'>${row.submittedAt}</td>`;
            tableBody.appendChild(tr);
        });
    }

    connection.start().then(() => connection.invoke('JoinTestGroup', 1)).catch(console.error);
</script>
